# Deploy state file
#
# Tracks the current and previous image tags so the deploy pipeline
# knows what is running and what to roll back to.
#
# This file is auto-generated by deploy-local.sh and rollback-deploy.sh.
# Do not edit manually unless recovering from a broken state.
#
# Add this file to .gitignore — it contains runtime state, not config.

REGISTRY=localhost:5000
CURRENT_TAG=
PREVIOUS_TAG=
